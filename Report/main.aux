\@writefile{lof}{\contentsline {figure}{\numberline {2.1}{\ignorespaces Refractive index (n, solid) and extinction coefficient (k, dashed) profiles of Crystalline Silicon (Si), Titanium Dioxide (TiO$_2$), and Silicon Nitride (Si$_3$N$_4$) across the visible and near-infrared spectrum. Silicon is seen to consistently have the highest refractive index, but also has the highest exctinction coefficient leading to potential parasitic losses in the grating. Silicon Nitride is nearly lossless across the entire region, and has an almost constant refractive index near 2.}}{4}{figure.caption.4}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:refractive_indices}{{2.1}{4}{Refractive index (n, solid) and extinction coefficient (k, dashed) profiles of Crystalline Silicon (Si), Titanium Dioxide (TiO$_2$), and Silicon Nitride (Si$_3$N$_4$) across the visible and near-infrared spectrum. Silicon is seen to consistently have the highest refractive index, but also has the highest exctinction coefficient leading to potential parasitic losses in the grating. Silicon Nitride is nearly lossless across the entire region, and has an almost constant refractive index near 2}{figure.caption.4}{}}
\newlabel{fig:refractive_indices@cref}{{[figure][1][0,2]2.1}{[1][4][]4}{}{}{}}
